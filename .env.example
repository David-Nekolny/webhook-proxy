# Server
PORT=3000
LOG_LEVEL=info

# GitHub webhook secret (from GitHub → Settings → Webhooks → Secret)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Vercel webhook secret (from Vercel → Project → Settings → Webhooks → Secret)
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret

# Gmail / Google Cloud Pub/Sub push token
# Must match the token appended to the push subscription URL:
#   https://your-host/webhooks/gmail?token=<GMAIL_PUBSUB_TOKEN>
# (Google sends it as Authorization: Bearer <token>)
GMAIL_PUBSUB_TOKEN=your-pubsub-bearer-token

# OpenClaw forwarding target
OPENCLAW_WEBHOOK_URL=http://localhost:3210/webhooks/external

# Shared secret sent with every forwarded request
PROXY_SECRET=your-strong-random-proxy-secret
