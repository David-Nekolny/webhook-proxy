# Server
PORT=3000
LOG_LEVEL=info

# GitHub webhook secret (GitHub → Settings → Webhooks → Secret)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Vercel webhook secret (Vercel → Project → Settings → Webhooks → Secret)
VERCEL_WEBHOOK_SECRET=your-vercel-webhook-secret

# Gmail / Google Cloud Pub/Sub push token
GMAIL_PUBSUB_TOKEN=your-pubsub-bearer-token

# OpenClaw gateway URL (local — webhook-proxy must run on the same machine)
OPENCLAW_WEBHOOK_URL=http://localhost:18789

# OpenClaw hooks token (openclaw.json → hooks.token)
OPENCLAW_HOOKS_TOKEN=your-openclaw-hooks-token
